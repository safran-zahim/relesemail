# Docker Port Configuration
# Host port for the application (container always runs on port 80)
# Change this to run on a different port (e.g., 3001, 8080, 5173)
HOST_PORT=3000

# Other environment variables
NODE_ENV=production

# Email API secrets used by the containerized Node server
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_USER=
GMAIL_REDIRECT_URI=https://developers.google.com/oauthplayground
MY_SECRET_KEY=
