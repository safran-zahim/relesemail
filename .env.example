# Docker Port Configuration
# Host port for the application (container listens on port 3000)
# Change this to run on a different host port (e.g., 3001, 8080, 5173)
HOST_PORT=3000

# Other environment variables
NODE_ENV=production

# --- EMAIL CONFIGURATION ---
# You can use a testing service like Mailtrap, or a real provider like Gmail.

# OPTION 1: Mailtrap (For Local Testing)
# Emails sent here will NOT reach real inboxes. They go to your Mailtrap dashboard.
# Sign up at https://mailtrap.io and copy your sandbox SMTP credentials below.
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_SECURE=false
SMTP_USER=your_mailtrap_user
SMTP_PASS=your_mailtrap_pass
SMTP_FROM=noreply@yourdomain.com

# OPTION 2: Real Delivery via Gmail
# Emails sent here WILL reach real user inboxes.
# Create a 16-character App Password in your Google Account Security settings.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_16_character_app_password
# SMTP_FROM=your_email@gmail.com

# --- SECURITY ---
# A secret key to prevent unauthorized access to the email sending API.
# This must match between your frontend deployment and backend.
MY_SECRET_KEY=OrangeHRM_2026_Secure_Key_!@#
